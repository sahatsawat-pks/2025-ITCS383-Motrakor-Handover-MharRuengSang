{
  "name": "steamjek-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "posttest": "node -e \"const fs=require('fs'); const p='coverage/lcov.info'; if(fs.existsSync(p)) fs.writeFileSync(p, fs.readFileSync(p, 'utf8').replace(/^SF:/gm, 'SF:Implementations/steamjek-backend/'));\"",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "posttest:coverage": "node -e \"const fs=require('fs'); const p='coverage/lcov.info'; if(fs.existsSync(p)) fs.writeFileSync(p, fs.readFileSync(p, 'utf8').replace(/^SF:/gm, 'SF:Implementations/steamjek-backend/'));\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "stripe": "^20.4.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/globalSetup.js",
    "globalTeardown": "./tests/globalTeardown.js",
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "routes/**/*.js",
      "middleware/**/*.js",
      "db/**/*.js",
      "config/**/*.js",
      "server.js",
      "!node_modules/**",
      "!tests/**",
      "!coverage/**"
    ],
    "coverageThreshold": {}
  }
}
